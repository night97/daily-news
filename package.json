{
  "name": "daily-report",
  "version": "1.0.0",
  "description": "自动化日报系统 - 每日收集关注领域最新资讯，生成响应式日报网站",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "concurrently \"npm run server\" \"npm run watch\"",
    "server": "nodemon backend/server.js",
    "generate": "node backend/scraper/generate.js",
    "generate:real": "node backend/scraper/generate.js --real",
    "generate:archive": "node backend/scraper/generate.js --real --archive",
    "build": "npm run generate:archive",
    "watch": "chokidar \"backend/scraper/**/*.js\" -c \"npm run generate\"",
    "deploy": "npm run build && gh-pages -d docs",
    "test": "jest"
  },
  "keywords": [
    "daily",
    "news",
    "report",
    "automation",
    "github-pages"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "concurrently": "^8.2.2",
    "gh-pages": "^6.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  }
}